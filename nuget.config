<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================
     VERIXORA – nuget.config
     ============================================================
     Summary:
       Explicitly configures NuGet package sources for all
       developers and CI. We clear the default sources and
       only allow NuGet.org.

       Why: If a developer has a custom local feed or a
       compromised upstream proxy, clearing defaults ensures
       all packages come from the trusted public source.
       Supply-chain security (ADR-012).

       The private feed is commented out for now but shows
       where internal packages would be added.
     ============================================================ -->
<configuration>
    <packageSources>
        <!-- Clear all inherited sources (machine-wide, user profile).
         This ensures the solution is self-contained and
         doesn't accidentally pull from an untrusted feed. -->
        <clear />

        <!-- Official NuGet.org source (HTTPS required). -->
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />

        <!-- Private feed placeholder (for future internal packages).
         Remove the comment markers when the feed is ready. -->
        <!-- <add key="private" value="https://pkgs.dev.azure.com/your-org/_packaging/verixora/nuget/v3/index.json" /> -->
    </packageSources>

    <!-- No disabled sources currently. -->
    <disabledPackageSources />
</configuration>
